# Copy to `.env` (already gitignored) and fill your own values.
#
# Secrets: never commit real keys/tokens to the repo.

# Weights & Biases (optional)
WANDB_API_KEY=
WANDB_BASE_URL=

# Training outputs (optional)
# BASE_OUTPUT_DIR=./outputs/Qwen2.5-Intuitor-3B
BASE_OUTPUT_DIR=

# vLLM / model (optional; can be a local path or a HuggingFace repo id)
# VLLM_MODEL_NAME_OR_PATH=Qwen/Qwen2.5-3B
VLLM_MODEL_NAME_OR_PATH=

# HuggingFace cache locations (optional)
HF_HOME=
HF_DATASETS_CACHE=
HF_HUB_CACHE=
